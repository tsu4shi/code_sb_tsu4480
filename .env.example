# Finnhub API key (required for US market news fetching)
# Get yours at: https://finnhub.io/register
FINNHUB_API_KEY=your_api_key_here

# Supabase (optional — enables cloud sync for the kakeibo tool)
# See docs/supabase-setup.md for setup instructions.
# Leave empty to use localStorage-only mode.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
