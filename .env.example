# Finnhub API key (required for US market news fetching)
# Get yours at: https://finnhub.io/register
FINNHUB_API_KEY=your_api_key_here

# Google OAuth client ID (required for kakeibo / receipts browser login)
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins:
#   http://localhost:1235 (kakeibo)
#   http://localhost:1236 (receipts)
#   and your GitHub Pages URL
GOOGLE_CLIENT_ID=your_google_client_id_here

# Receipts Document AI auth: do NOT put service-account JSON or API keys here.
# The browser uses a short-lived OAuth access token (memory only) with scope
# cloud-platform after the user clicks "Document AI を許可".
